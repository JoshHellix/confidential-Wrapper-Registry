# Copy these into Vercel → Project → Settings → Environment Variables
# (Production + Preview). Do NOT commit real keys to git.

NEXT_PUBLIC_SEPOLIA_RPC=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
NEXT_PUBLIC_MAINNET_RPC=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
# Leave empty for Sepolia-only demo (Zama testnet relayer needs no key):
NEXT_PUBLIC_RELAYER_PROXY=
